{
  "info": {
    "name": "CourseHunter - Course Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "courseId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Queries",
      "item": [
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"]
            }
          }
        },
        {
          "name": "Get Course By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/courses/{{courseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses", "{{courseId}}"]
            }
          }
        },
        {
          "name": "Filter By Tag",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/courses?tag=java",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"],
              "query": [
                { "key": "tag", "value": "java" }
              ]
            }
          }
        },
        {
          "name": "Filter By Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/courses?status=PUBLISHED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"],
              "query": [
                { "key": "status", "value": "PUBLISHED" }
              ]
            }
          }
        },
        {
          "name": "Search By Title",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/courses?search=spring",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"],
              "query": [
                { "key": "search", "value": "spring" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Commands",
      "item": [
        {
          "name": "Create Course",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('courseId', json.id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has ID', () => pm.expect(json.id).to.not.be.undefined);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Boot Mastery\",\n  \"description\": \"Learn Spring Boot from scratch\",\n  \"instructorName\": \"John Doe\",\n  \"totalSeats\": 30,\n  \"startDate\": \"2026-06-01\",\n  \"endDate\": \"2026-08-01\",\n  \"tagSlugs\": [\"spring-boot\", \"java\", \"microservices\"]\n}"
            }
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/courses/{{courseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses", "{{courseId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Boot Advanced\",\n  \"totalSeats\": 50\n}"
            }
          }
        },
        {
          "name": "Publish Course",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/courses/{{courseId}}/publish",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses", "{{courseId}}", "publish"]
            }
          }
        },
        {
          "name": "Archive Course",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/courses/{{courseId}}/archive",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses", "{{courseId}}", "archive"]
            }
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/courses/{{courseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses", "{{courseId}}"]
            }
          }
        }
      ]
    }
  ]
}
